{
  "version": 2,
  "framework": "vite",
  "buildCommand": "node prepare-build.js && npm install --prefix frontend && npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
